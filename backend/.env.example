PORT=5000
NODE_ENV=production
JWT_SECRET=generate_a_secure_random_string_here
ADMIN_PASSWORD=change_this_to_secure_password
MONGODB_URI_BRANCH1=mongodb+srv://username:password@cluster.mongodb.net/branch1
MONGODB_URI_BRANCH2=mongodb+srv://username:password@cluster.mongodb.net/branch2

# Branch Contact Information
BRANCH1_PHONE=+91 XXXXX XXXXX
BRANCH2_PHONE=+91 XXXXX XXXXX

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_ENV=sandbox

# Frontend and Backend URLs
FRONTEND_URL=https://your-frontend-url.com
BACKEND_URL=https://your-backend-url.com

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
ADMIN_EMAIL=admin@friendsandmemories.in
BRANCH1_EMAIL=branch1@friendsandmemories.in
BRANCH2_EMAIL=branch2@friendsandmemories.in
EMAIL_FROM_NAME=Friends And Memories

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
